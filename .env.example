# ===== Ports (host binding via docker-compose) =====
FE_PORT=45173
BE_PORT=45174

# ===== Public origins (set when domain ready) =====
FRONTEND_ORIGIN=http://localhost:45173
API_ORIGIN=http://localhost:45174
NEXT_PUBLIC_API_ORIGIN=http://localhost:45174

# ===== Auth =====
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change_me_now
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_TTL=1d
REFRESH_TOKEN_TTL=45d
COOKIE_SECURE=false

# ===== Storage =====
HOST_MEDIA_MOUNT_POINT=/mnt/data-hgst
MEDIA_MOUNT_POINT=/data
MEDIA_LIBRARY_PATH=/data/library
MEDIA_DERIVED_PATH=/data/library/derived
MEDIA_TRASH_PATH=/data/library/trash
STORAGE_USAGE_CACHE_SECONDS=60

# ===== Database / Redis =====
POSTGRES_DB=hcphotos
POSTGRES_USER=hcphotos
POSTGRES_PASSWORD=hcphotos_local_dev
DATABASE_URL=postgresql://hcphotos:hcphotos_local_dev@db:5432/hcphotos
REDIS_URL=redis://redis:6379

# ===== Worker =====
WORKER_CONCURRENCY=2
